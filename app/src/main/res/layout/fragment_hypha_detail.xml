<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F6F0E8">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Hypha"
        android:background="#F6F0E8"
        app:navigationIcon="@android:drawable/ic_media_previous" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewHyphaBadge"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="FA"
                    android:textStyle="bold"
                    android:background="@android:drawable/dialog_holo_light_frame" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewHyphaName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nome da Hypha"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textViewHyphaType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="PRIVATE"
                        android:textColor="#5F5A54" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textViewHyphaDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Descrição da hypha" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenChat"
                style="@style/Widget.Micelios.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Abrir chat" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Membros"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#FFFDF9"
                android:padding="12dp"
                android:text="Lista de membros" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Momentos"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewHyphaMoments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#FFFDF9"
                android:padding="12dp"
                android:text="Momentos da hypha" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>