<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F0E8">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Nova Hypha"
        app:navigationIcon="@android:drawable/ic_media_previous" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/editTextHyphaName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome da Hypha" />

        <EditText
            android:id="@+id/editTextHyphaDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Descrição" />

        <EditText
            android:id="@+id/editTextMemberUserId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="ID do membro"
            android:inputType="number" />

        <EditText
            android:id="@+id/editTextMemberDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Nome do membro" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCreateHypha"
            style="@style/Widget.Micelios.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Criar Hypha" />

    </LinearLayout>
</LinearLayout>