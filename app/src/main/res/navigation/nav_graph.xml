<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.micelios.presentation.auth.WelcomeFragment"
        android:label="Welcome">

        <action
            android:id="@+id/action_welcomeFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.micelios.presentation.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.micelios.presentation.profile.ProfileFragment"
        android:label="Perfil" />

    <fragment
        android:id="@+id/hyphaListFragment"
        android:name="com.example.micelios.presentation.hypha.HyphaListFragment"
        android:label="Hyphas">
        <action
            android:id="@+id/action_hyphaListFragment_to_hyphaDetailFragment"
            app:destination="@id/hyphaDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/momentListFragment"
        android:name="com.example.micelios.presentation.moments.MomentListFragment"
        android:label="Postar Momento" />

    <fragment
        android:id="@+id/hyphaDetailFragment"
        android:name="com.example.micelios.presentation.hypha.HyphaDetailFragment"
        android:label="Hypha">
        <action
            android:id="@+id/action_hyphaDetailFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.micelios.presentation.chat.ChatFragment"
        android:label="Chat" />
</navigation>